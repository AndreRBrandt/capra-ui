{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "paths": {
      "@capra-ui/core": ["../src/index.ts"],
      "@/*": ["../src/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*", "src/**/*.vue", "data/**/*.json"]
}
